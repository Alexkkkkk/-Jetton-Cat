modules = ["nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx blueprint run deployContract"

[deployment]
deploymentTarget = "vm"
run = ["node", "-e", "console.log('jetton-cat: TON smart contract project. Run npm run build to compile contracts.')"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
NETWORK_TYPE = "mainnet"
WALLET_VERSION = "v4"
